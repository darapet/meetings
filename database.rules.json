{
  "rules": {

    "users": {
      "$uid": {
        ".read":  "auth != null && $uid == auth.uid",
        ".write": "auth != null && $uid == auth.uid"
      }
    },

    "meetings": {
      "$meetingId": {
        ".read": "auth != null",
        ".write": "auth != null && (!data.exists() || data.child('hostId').val() == auth.uid)",
        "participants": {
          "$uid": {
            ".write": "auth != null && ($uid == auth.uid || root.child('meetings').child($meetingId).child('hostId').val() == auth.uid)"
          }
        },
        "summaries": {
          "$sumId": {
            ".write": "auth != null && root.child('meetings').child($meetingId).child('hostId').val() == auth.uid"
          }
        }
      }
    },

    "chat": {
      "$meetingId": {
        ".read":  "auth != null",
        "$msgId": {
          ".write": "auth != null && !data.exists() && newData.child('uid').val() == auth.uid"
        }
      }
    },

    "presence": {
      "$meetingId": {
        ".read":  "auth != null",
        "$uid":   { ".write": "auth != null && $uid == auth.uid" }
      }
    },

    "signals": {
      "$meetingId": {
        ".read":  "auth != null",
        ".write": "auth != null"
      }
    },

    "rooms": {
      "$meetingId": {
        ".read":  "auth != null",
        ".write": "auth != null"
      }
    },

    "joinRequests": {
      "$meetingId": {
        ".read": "auth != null",
        "$uid": {
          ".write": "auth != null && ($uid == auth.uid || root.child('meetings').child($meetingId).child('hostId').val() == auth.uid)"
        }
      }
    }

  }
}
